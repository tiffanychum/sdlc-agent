POE_API_KEY=your_poe_api_key_here
LLM_BASE_URL=https://api.poe.com/v1
LLM_MODEL=gpt-5.3-codex
# Role-specific models (optional — falls back to LLM_MODEL if unset)
LLM_JUDGE_MODEL=gpt-4o-mini
LLM_RCA_MODEL=deepseek-r1
LLM_ROUTER_MODEL=gpt-4o-mini
GITHUB_TOKEN=your_github_token_here
# Jira MCP (optional)
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=

# Filesystem MCP (optional)
# AGENT_WORKSPACE=/path/to/project
# AGENT_ALLOW_ABSOLUTE_PATHS=1

# OpenTelemetry (optional — export to Phoenix, Jaeger, or any OTel backend)
OTEL_EXPORTER_OTLP_ENDPOINT=
# DeepEval (optional — for external cross-validation)
DEEPEVAL_KEY=
# Langfuse (optional — trace export)
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
